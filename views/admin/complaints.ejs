<% layout('layouts/boilerplate') -%>

<div class="layout">
  <%- include("../includes/adminSidebar", { active: "complaints" }) %>

  <div class="main admin-bg">
    <%- include("../includes/adminNavbar", { user }) %>

    <div class="container mt-4">

      <!-- ================= HEADER ================= -->
      <div class="mb-4">
        <div class="page-title">Complaints Management</div>
        <div class="subtitle">Review and resolve student complaints</div>
      </div>

      <!-- ================= STATS ================= -->
      <div class="row g-4 mb-4">

        <div class="col-md-3">
          <div class="stat-card1">
            <div class="stat-icon1 icon-gray">
              <i class="bi bi-inbox"></i>
            </div>
            <div>
              <h4 class="mb-0"><%= totalComplaints %></h4>
              <small class="text-muted">Total Complaints</small>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <div class="stat-card1">
            <div class="stat-icon1 icon-yellow">
              <i class="bi bi-clock"></i>
            </div>
            <div>
              <h4 class="mb-0"><%= pendingCount %></h4>
              <small class="text-muted">Pending</small>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <div class="stat-card1">
            <div class="stat-icon1 icon-blue">
              <i class="bi bi-exclamation-triangle"></i>
            </div>
            <div>
              <h4 class="mb-0"><%= progressCount %></h4>
              <small class="text-muted">In Progress</small>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <div class="stat-card1">
            <div class="stat-icon1 icon-green">
              <i class="bi bi-check-circle"></i>
            </div>
            <div>
              <h4 class="mb-0"><%= resolvedCount %></h4>
              <small class="text-muted">Resolved</small>
            </div>
          </div>
        </div>

      </div>

      <!-- ================= FILTER BAR ================= -->
      <form class="filter-bar mb-4" method="GET">
        <div class="row g-3">
          <div class="col-md-5">
            <input class="form-control" name="q" placeholder="Search complaints..." value="<%= filters.q %>">
          </div>
          <div class="col-md-3">
            <select class="form-select" name="status">
              <option value="">All Status</option>
              <option value="pending">Pending</option>
              <option value="in-progress">In Progress</option>
              <option value="resolved">Resolved</option>
            </select>
          </div>
          <div class="col-md-3">
            <select class="form-select" name="category">
              <option value="">All Categories</option>
              <option>Food</option>
              <option>Hygiene</option>
              <option>Billing</option>
              <option>Other</option>
            </select>
          </div>
          <div class="col-md-1">
            <button class="btn btn-dark w-100">Go</button>
          </div>
        </div>
      </form>

      <!-- ================= COMPLAINT LIST ================= -->
      <% complaints.forEach(c => { %>

        <div class="complaint-card-modern mb-3">

          <div class="d-flex justify-content-between">

            <div>
              <h5 class="mb-1">
                <%= c.title %>
                <span class="badge bg-light text-dark ms-2"><%= c.category %></span>
              </h5>

              <p class="text-muted mb-2">
                <%= c.description.slice(0,120) %>...
              </p>

              <small class="text-muted">
                <i class="bi bi-person"></i>
                <%= c.student?.name || c.student?.username %>
                &nbsp; • &nbsp;
                <i class="bi bi-calendar"></i>
                <%= c.createdAt.toDateString() %>
              </small>
            </div>

            <div class="text-end">

              <span class="status-badge 
                <%= c.status==='pending' ? 'status-pending' :
                    c.status==='in-progress' ? 'status-in-progress' :
                    'status-resolved' %>">
                <%= c.status %>
              </span>

              <br>

              <button
                class="btn btn-success btn-sm mt-2 open-btn"
                data-bs-toggle="modal"
                data-bs-target="#modal-<%= c._id %>">
                Open
              </button>

            </div>

          </div>

        </div>

        <!-- ================= MODAL ================= -->
        <div class="modal fade" id="modal-<%= c._id %>" tabindex="-1">
          <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content p-3">

              <div class="modal-header border-0">
                <div>
                  <h4><%= c.title %></h4>
                  <span class="badge bg-warning text-dark"><%= c.category %></span>
                  <span class="badge bg-light text-dark"><%= c.status %></span>
                </div>
                <button class="btn-close" data-bs-dismiss="modal"></button>
              </div>

              <div class="modal-body">

                <div class="mb-3 text-muted">
                  <i class="bi bi-person"></i>
                  <%= c.student?.name %>
                  &nbsp; • &nbsp;
                  <i class="bi bi-calendar"></i>
                  <%= c.createdAt.toDateString() %>
                </div>

                <div class="description-box mb-4">
                  <strong>Description</strong>
                  <p class="mt-2 mb-0"><%= c.description %></p>
                </div>

                <form method="POST" action="/admins/complaints/<%= c._id %>?_method=PUT">
                  <div class="mb-3">
                    <label>Status</label>
                    <select class="form-select" name="status">
                      <option value="pending">Pending</option>
                      <option value="in-progress">In Progress</option>
                      <option value="resolved">Resolved</option>
                    </select>
                  </div>

                  <div class="mb-3">
                    <label>Admin Note</label>
                    <textarea class="form-control" rows="4"
                      name="adminNote"
                      placeholder="Add a note about this complaint..."><%= c.adminNote || '' %></textarea>
                  </div>

                  <div class="d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                    <button class="btn btn-success">Save Changes</button>
                  </div>
                </form>

              </div>

            </div>
          </div>
        </div>

      <% }) %>

    </div>
    <%- include("../includes/footer") %>
  </div>
</div>