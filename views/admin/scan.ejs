<% layout('layouts/boilerplate') -%>

    <div class="layout">
        <%- include("../includes/adminSidebar", { active: "attendance" , role: "admin" }) %>

            <div class="main">
                <%- include("../includes/adminNavbar", { user }) %>

                    <div class="layout">
                        <div class="main full-width">

                            <div class="scanner-page">

                                <h1>Mess Attendance Scanner</h1>
                                <p class="subtitle">Scan student QR to mark attendance</p>

                                <div class="scanner-card">

                                    <div id="reader"></div>

                                    <div id="scanStatus" class="scan-badge">
                                        🟢 Ready to Scan
                                    </div>

                                    <div id="resultBox" class="result-box hidden">
                                        <!-- Filled dynamically -->
                                    </div>

                                </div>

                            </div>

                        </div>
                    </div>

                    <script src="https://unpkg.com/html5-qrcode"></script>
                    <script src="/js/scanQr.js"></script>
                    <script>
                        initQrScanner();
                    </script>

            </div>
    </div>