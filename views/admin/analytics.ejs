<% layout('layouts/boilerplate') -%>

<div class="layout">
  <%- include("../includes/adminSidebar", { active: "analytics" }) %>

  <div class="main bg-light-custom">
    <%- include("../includes/adminNavbar") %>

    <div class="page-content">
      <div class="container py-4">
        <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
          <div>
            <h2 class="fw-bold mb-1">Scan Analytics</h2>
            <div class="text-muted">
              Today: <%= stats.today.toDateString() %>
            </div>
          </div>
          <div class="d-flex gap-2 flex-wrap">
            <a href="/admins/audit-logs" class="btn btn-outline-dark btn-sm">
              <i class="bi bi-journal-text me-1"></i>
              View all logs
            </a>
            <a href="/admins/scan" class="btn btn-primary btn-sm">
              <i class="bi bi-qr-code-scan me-1"></i>
              Open Scanner
            </a>
          </div>
        </div>

        <div class="row g-4 mb-4">
          <div class="col-md-3">
            <div class="dashboard-card h-100">
              <div class="text-muted small">Total scans today</div>
              <div class="fs-3 fw-bold"><%= stats.total %></div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="dashboard-card h-100">
              <div class="text-muted small">Accepted</div>
              <div class="fs-3 fw-bold text-success"><%= stats.accepted %></div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="dashboard-card h-100">
              <div class="text-muted small">Rejected</div>
              <div class="fs-3 fw-bold text-danger"><%= stats.rejected %></div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="dashboard-card h-100">
              <div class="text-muted small">Duplicate</div>
              <div class="fs-3 fw-bold text-warning"><%= stats.duplicate %></div>
            </div>
          </div>
        </div>

        <div class="row g-4 mb-4">
          <div class="col-lg-6">
            <div class="dashboard-card h-100">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="mb-0">Meal-wise (accepted today)</h5>
                <span class="badge bg-light text-dark">Today</span>
              </div>
              <div style="height: 260px;">
                <canvas id="mealChart"></canvas>
              </div>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="dashboard-card h-100">
              <h5 class="mb-2">Weekly average students</h5>
              <div class="text-muted small mb-3">
                Based on accepted scans (unique students per week).
              </div>
              <div class="d-flex align-items-end justify-content-between">
                <div>
                  <div class="text-muted small">Average</div>
                  <div class="fs-2 fw-bold"><%= avgWeekly.average %></div>
                </div>
                <div class="text-muted small">
                  Weeks considered: <%= avgWeekly.weeklyBreakdown.length %>
                </div>
              </div>

              <% if (missed.mealType) { %>
                <hr />
                <div class="d-flex justify-content-between align-items-start gap-3">
                  <div>
                    <div class="fw-semibold">Missed current meal: <%= missed.mealType %></div>
                    <div class="text-muted small">
                      Eligible active students who have not attended today.
                    </div>
                  </div>
                  <div class="fs-5 fw-bold"><%= missed.missedCount %></div>
                </div>

                <% if (missed.sample && missed.sample.length) { %>
                  <div class="mt-2 text-muted small">
                    Sample:
                    <% missed.sample.forEach((s, idx) => { %>
                      <%= s.username %><%= idx < missed.sample.length - 1 ? ", " : "" %>
                    <% }) %>
                  </div>
                <% } %>
              <% } else { %>
                <hr />
                <div class="text-muted small">
                  Missed-meal analytics is only shown during meal hours.
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <div class="dashboard-card">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Recent scan logs</h5>
            <span class="text-muted small">Latest <%= recentLogs.length %></span>
          </div>

          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr class="text-muted small">
                  <th>Time</th>
                  <th>Student</th>
                  <th>Meal</th>
                  <th>Status</th>
                  <th>Reason</th>
                  <th>Scanner</th>
                </tr>
              </thead>
              <tbody>
                <% if (!recentLogs.length) { %>
                  <tr>
                    <td colspan="6" class="text-muted">No scan logs yet.</td>
                  </tr>
                <% } %>

                <% recentLogs.forEach(log => { %>
                  <tr>
                    <td class="text-muted small">
                      <%= log.scannedAt ? new Date(log.scannedAt).toLocaleString() : new Date(log.createdAt).toLocaleString() %>
                    </td>
                    <td class="fw-semibold"><%= log.studentName || log.target || "unknown" %></td>
                    <td><%= log.mealType || "-" %></td>
                    <td>
                      <% if (log.scanStatus === "accepted") { %>
                        <span class="badge bg-success">accepted</span>
                      <% } else if (log.scanStatus === "duplicate") { %>
                        <span class="badge bg-warning text-dark">duplicate</span>
                      <% } else { %>
                        <span class="badge bg-danger">rejected</span>
                      <% } %>
                    </td>
                    <td class="text-muted small"><%= log.reason || "-" %></td>
                    <td class="text-muted small"><%= log.scannerName || log.performedBy || "-" %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>

    <%- include("../includes/footer") %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script type="application/json" id="mealCountsJson"><%- JSON.stringify(stats.mealCounts) %></script>
<script>
  const mealCounts = JSON.parse(document.getElementById("mealCountsJson").textContent);
  const ctx = document.getElementById("mealChart");

  new Chart(ctx, {
    type: "bar",
    data: {
      labels: ["Breakfast", "Lunch", "Dinner"],
      datasets: [{
        label: "Accepted scans",
        data: [mealCounts.Breakfast, mealCounts.Lunch, mealCounts.Dinner],
        backgroundColor: ["rgba(16,185,129,0.35)", "rgba(37,99,235,0.35)", "rgba(245,158,11,0.35)"],
        borderColor: ["#10b981", "#2563eb", "#f59e0b"],
        borderWidth: 1,
        borderRadius: 10
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false } },
        y: { beginAtZero: true, ticks: { precision: 0 } }
      }
    }
  });
</script>

