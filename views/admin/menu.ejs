<% layout('layouts/boilerplate') -%>

    <div class="layout">
        <%- include("../includes/adminSidebar", { active: "menu" , role: "admin" }) %>

            <div class="main">
                <%- include("../includes/adminNavbar", { user }) %>

                    <div class="container py-4">

                        <!-- Header -->
                        <div class="mb-4">
                            <h2 class="fw-bold">⚙️ Manage Weekly Mess Menu</h2>
                            <p class="text-muted">Add, edit or remove meals for the week</p>
                        </div>

                        <!-- Add Menu Card -->
                        <div class="card shadow-sm border-0 rounded-4 mb-4">
                            <div class="card-body">

                                <h5 class="fw-semibold mb-3">Add Menu Items</h5>

                                <form action="/admins/menu" method="POST">
                                    <div class="row g-3">

                                        <div class="col-md-6">
                                            <label class="form-label">Day</label>
                                            <select name="day" class="form-select" required>
                                                <option value="">Select day</option>
                                                <option>Monday</option>
                                                <option>Tuesday</option>
                                                <option>Wednesday</option>
                                                <option>Thursday</option>
                                                <option>Friday</option>
                                                <option>Saturday</option>
                                                <option>Sunday</option>
                                            </select>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Meal</label>
                                            <select name="mealType" class="form-select" required>
                                                <option value="">Select meal</option>
                                                <option value="breakfast">Breakfast</option>
                                                <option value="lunch">Lunch</option>
                                                <option value="dinner">Dinner</option>
                                            </select>
                                        </div>

                                    </div>

                                    <div class="mt-4">
                                        <label class="form-label">Menu Items</label>

                                        <div id="items">
                                            <div class="row g-2 mb-2">
                                                <div class="col-md-9">
                                                    <input type="text" name="items[0][name]" class="form-control"
                                                        placeholder="Item name" required>
                                                </div>
                                                <div class="col-md-3">
                                                    <select name="items[0][isVeg]" class="form-select">
                                                        <option value="true">Veg</option>
                                                        <option value="false">Non-Veg</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>

                                        <button type="button" onclick="addItem()"
                                            class="btn btn-outline-secondary btn-sm mt-2">
                                            + Add Another Item
                                        </button>

                                    </div>

                                    <button type="submit" class="btn btn-success mt-3 px-4">
                                        + Add to Menu
                                    </button>

                                </form>
                            </div>
                        </div>

                        <!-- Current Menu -->
                        <div class="card shadow-sm border-0 rounded-4">
                            <div class="card-body">

                                <h5 class="fw-semibold mb-1">Current Weekly Menu</h5>
                                <p class="text-muted small">
                                    <%= menus.length %> meal entries configured
                                </p>

                                <div class="table-responsive">
                                    <table class="table align-middle">

                                        <thead class="table-light">
                                            <tr>
                                                <th>Day</th>
                                                <th>Meal</th>
                                                <th>Items</th>
                                                <th class="text-end">Actions</th>
                                            </tr>
                                        </thead>

                                        <tbody>
                                            <% menus.forEach(menu=> { %>

                                                <tr>
                                                    <!-- Day -->
                                                    <td class="fw-semibold">
                                                        <%= menu.day %>
                                                    </td>

                                                    <!-- Meal -->
                                                    <td class="text-capitalize text-muted">
                                                        <%= menu.mealType %>
                                                    </td>

                                                    <!-- Items -->
                                                    <td>
                                                        <% menu.items.forEach(item=> { %>

                                                            <div class="d-flex align-items-center mb-2 item-row"
                                                                data-id="<%= item._id %>">

                                                                <!-- Badge -->
                                                                <span class="badge rounded-pill me-2 px-3 py-1
                      <%= item.isVeg
                        ? 'bg-success-subtle text-success border border-success'
                        : 'bg-danger-subtle text-danger border border-danger' %>">
                                                                    <i
                                                                        class="bi <%= item.isVeg ? 'bi-leaf' : 'bi-egg-fried' %> me-1"></i>
                                                                    <%= item.isVeg ? 'Veg' : 'Non-Veg' %>
                                                                </span>

                                                                <!-- Name -->
                                                                <span class="item-text flex-grow-1">
                                                                    <%= item.name %>
                                                                </span>

                                                                <!-- Edit -->
                                                                <button class="btn btn-sm btn-link text-dark edit-btn">
                                                                    <i class="bi bi-pencil"></i>
                                                                </button>

                                                            </div>

                                                            <% }) %>
                                                    </td>

                                                    <!-- Delete -->
                                                    <td class="text-end">

                                                        <button class="btn btn-outline-danger btn-sm rounded-3"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#deleteModal<%= menu._id %>">
                                                            <i class="bi bi-trash me-1"></i> Meal
                                                        </button>

                                                        <!-- Modal -->
                                                        <div class="modal fade" id="deleteModal<%= menu._id %>"
                                                            tabindex="-1">
                                                            <div class="modal-dialog modal-dialog-centered">
                                                                <div class="modal-content rounded-4 shadow">

                                                                    <div class="modal-body p-4">
                                                                        <h5 class="fw-bold mb-3">Delete Entire Meal</h5>

                                                                        <p class="text-muted">
                                                                            This will remove
                                                                            <strong>
                                                                                <%= menu.day %>
                                                                                    <%= menu.mealType %>
                                                                            </strong>
                                                                            and all its items.
                                                                            This cannot be undone.
                                                                        </p>

                                                                        <div class="text-end mt-4">
                                                                            <button class="btn btn-light me-2"
                                                                                data-bs-dismiss="modal">
                                                                                Cancel
                                                                            </button>

                                                                            <form
                                                                                action="/admins/menu/delete/<%= menu._id %>"
                                                                                method="POST" class="d-inline">
                                                                                <button
                                                                                    class="btn btn-danger rounded-3">
                                                                                    Delete
                                                                                </button>
                                                                            </form>
                                                                        </div>
                                                                    </div>

                                                                </div>
                                                            </div>
                                                        </div>

                                                    </td>

                                                </tr>

                                                <% }) %>
                                        </tbody>

                                    </table>
                                </div>

                            </div>
                        </div>

                    </div>
            </div>

            <script src="/js/adminMenu.js"></script>

            <!-- Bootstrap Icons -->
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">