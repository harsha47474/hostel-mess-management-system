<% layout('layouts/boilerplate') -%>

    <div class="layout">
        <%- include("../includes/adminSidebar", { active: "dashboard" , role: "admin" }) %>

            <div class="main">
                <%- include("../includes/adminNavbar", { user }) %>

                    <div class="content">
                        <h2>Admin Dashboard 📊</h2>
                        <p class="subtitle">Overview of hostel mess management</p>

                        <!-- Stats Cards -->
                        <div class="admin-cards">

                            <div class="admin-card">
                                <div class="card-top">
                                    <span>Total Students</span>
                                </div>
                                <h1>
                                    <b><%= totalStudents %></b>
                                    <span class="card-icon">🎓</span>
                                </h1>
                                <p class="card-sub" style="color: green;">+12 this month</p>
                            </div>

                            <div class="admin-card">
                                <div class="card-top">
                                    <span>Pending Bills</span>
                                    
                                </div>
                                <h1 style="color: red;"><b>₹<%= totalPendingBills %></b>
                                    <span class="card-icon">💰</span>
                                </h1>
                                <p class="card-sub">
                                    <%= totalStudents %>
                                </p>
                            </div>

                            <div class="admin-card">
                                <div class="card-top">
                                    <span>Complaints Pending</span>
                                </div>
                                <h1>
                                    <%= pendingComplaints %>
                                    <span class="card-icon">💬</span>
                                </h1>
                                <p class="card-sub">3 urgent</p>
                            </div>

                            <div class="admin-card">
                                <div class="card-top">
                                    <span>Overall Attendance</span>
                                   
                                </div>
                                <h1>
                                    <%= attendanceRate %>%
                                     <span class="card-icon">📅</span>
                                </h1>
                                <p class="card-sub">This month</p>
                            </div>

                        </div>

                        <div class="activity-section">
                            <h3>Recent Activity</h3>

                            <% if (activities.length===0) { %>
                                <p>No recent activity yet.</p>
                                <% } else { %>
                                    <% activities.forEach(a=> { %>
                                        <div class="activity-item">
                                            <div>
                                                <strong>
                                                    <%= a.message %>
                                                </strong>
                                                <p>by <%= a.by %>
                                                </p>
                                            </div>
                                            <span>
                                                <% if (a.time) { %>
                                                    <%= new Date(a.time).toLocaleString() %>
                                                        <% } else { %>
                                                            N/A
                                                            <% } %>
                                            </span>
                                        </div>
                                        <% }) %>
                                            <% } %>
                        </div>

                    </div>

            </div>
    </div>