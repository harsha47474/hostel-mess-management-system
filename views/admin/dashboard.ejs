<% layout('layouts/boilerplate') -%>

    <div class="layout">

        <%- include("../includes/adminSidebar", { active: "dashboard" }) %>

            <div class="main bg-light-custom">

                <%- include("../includes/adminNavbar") %>

                    <div class="container mt-4">

                        <div class="mb-4">
                            <div class="dashboard-title">Admin Dashboard</div>
                            <div class="dashboard-subtitle">
                                Overview of your hostel mess operations
                            </div>
                        </div>

                        <!-- ================= STAT CARDS ================= -->
                        <div class="row g-4">

                            <!-- Total Students -->
                            <div class="col-md-3">
                                <div class="stat-card blue">
                                    <div class="stat-title">Total Students</div>
                                    <div class="stat-value">
                                        <%= totalStudents %>
                                    </div>
                                    <div class="stat-subtext">+12 this month</div>
                                    <div class="stat-icon">
                                        <i class="bi bi-people"></i>
                                    </div>
                                </div>
                            </div>

                            <!-- Active -->
                            <div class="col-md-3">
                                <div class="stat-card green">
                                    <div class="stat-title">Active Subscriptions</div>
                                    <div class="stat-value text-success">
                                        <%= activeCount %>
                                    </div>
                                    <div class="stat-subtext">87% of total</div>
                                    <div class="stat-icon">
                                        <i class="bi bi-check-circle"></i>
                                    </div>
                                </div>
                            </div>

                            <!-- Expired -->
                            <div class="col-md-3">
                                <div class="stat-card red">
                                    <div class="stat-title">Expired Subscriptions</div>
                                    <div class="stat-value text-danger">
                                        <%= expiredCount %>
                                    </div>
                                    <div class="stat-subtext">8% of total</div>
                                    <div class="stat-icon">
                                        <i class="bi bi-x-circle"></i>
                                    </div>
                                </div>
                            </div>

                            <!-- Expiring -->
                            <div class="col-md-3">
                                <div class="stat-card yellow">
                                    <div class="stat-title">Expiring Soon</div>
                                    <div class="stat-value text-warning">
                                        <%= expiringSoonCount %>
                                    </div>
                                    <div class="stat-subtext">Next 7 days</div>
                                    <div class="stat-icon">
                                        <i class="bi bi-exclamation-triangle"></i>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <!-- ================= BOTTOM SECTION ================= -->
                        <div class="row mt-5 g-4">

                            <!-- RECENT ACTIVITY -->
                            <div class="col-md-4">
                                <div class="dashboard-card h-100">
                                    <h5 class="mb-4">Recent Activity</h5>

                                    <% if (activities.length===0) { %>
                                        <p class="text-muted">No recent activity</p>
                                        <% } %>

                                            <% activities.forEach(activity=> { %>

                                                <% let iconClass="bi-clock" ; let colorClass="activity-blue" ; if
                                                    (activity.action.includes("renewed")) { iconClass="bi-arrow-repeat"
                                                    ; colorClass="activity-green" ; } else if
                                                    (activity.action.includes("registered")) {
                                                    iconClass="bi-person-plus" ; colorClass="activity-blue" ; } else if
                                                    (activity.action.includes("expired")) {
                                                    iconClass="bi-exclamation-triangle" ; colorClass="activity-yellow" ;
                                                    } else if (activity.action.includes("Payment")) {
                                                    iconClass="bi-currency-rupee" ; colorClass="activity-green" ; } else
                                                    if (activity.action.includes("deleted")) { iconClass="bi-trash" ;
                                                    colorClass="activity-red" ; } %>

                                                    <div class="activity-item">
                                                        <div class="activity-left">
                                                            <div class="activity-icon <%= colorClass %>">
                                                                <i class="bi <%= iconClass %>"></i>
                                                            </div>

                                                            <div>
                                                                <div class="activity-title">
                                                                    <%= activity.performedBy %>
                                                                </div>
                                                                <div class="activity-sub">
                                                                    <%= activity.action %>
                                                                        <strong>
                                                                            <%= activity.target %>
                                                                        </strong>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div class="activity-time">
                                                            <%= new Date(activity.createdAt).toLocaleTimeString() %>
                                                        </div>
                                                    </div>

                                                    <% }) %>
                                </div>
                            </div>
                            <!-- REVENUE -->
                            <div class="col-md-4">
                                <div class="dashboard-card">
                                    <div class="d-flex justify-content-between mb-3">
                                        <h5>Monthly Revenue</h5>
                                        <span class="badge bg-light text-dark">Last 6 months</span>
                                    </div>
                                    <div class="chart-container">
                                        <canvas id="revenueChart"></canvas>
                                    </div>
                                </div>
                            </div>

                            <!-- FOOD DONUT -->
                            <div class="col-md-4">
                                <div class="dashboard-card">
                                    <h5 class="mb-4">Food Preference</h5>
                                    <div class="chart-container">
                                        <canvas id="foodChart"></canvas>
                                    </div>
                                </div>
                            </div>

                        </div>

                    </div>
                    <%- include("../includes/footer") %>

            </div>
    </div>

    <!-- ================= CHART.JS CDN ================= -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // ===== REVENUE LINE =====
        new Chart(document.getElementById('revenueChart'), {
            type: 'line',
            data: {
                labels: <%- JSON.stringify(labels) %>,
                datasets: [{
                    data: <%- JSON.stringify(revenueData) %>,
                    borderColor: '#10b981',
                    backgroundColor: 'rgba(16,185,129,0.12)',
                    borderWidth: 3,
                    tension: 0.4,
                    fill: true,
                    pointRadius: 5,
                    pointHoverRadius: 7,
                    pointBackgroundColor: '#10b981'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: {
                    duration: 1500,
                    easing: 'easeOutQuart'
                },
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        grid: { display: false }
                    },
                    y: {
                        beginAtZero: true,
                        grid: {
                            color: '#f1f5f9'
                        }
                    }
                }
            }
        });

        // ===== VEG / NON-VEG DONUT =====
        new Chart(document.getElementById('foodChart'), {
            type: 'doughnut',
            data: {
                labels: ['Veg', 'Non-Veg'],
                datasets: [{
                    data: [<%= vegCount %>, <%= nonVegCount %>],
                    backgroundColor: ['#22c55e', '#ef4444'],
                    borderWidth: 0,
                    hoverOffset: 12
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                animation: {
                    animateRotate: true,
                    duration: 1500
                },
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });
    </script>