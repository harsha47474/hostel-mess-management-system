<% layout('layouts/boilerplate') -%>

<div class="layout">
  <%- include("../includes/sidebar", { active: "dashboard" }) %>

  <div class="main student-bg">
    <%- include("../includes/navbar", { user }) %>

    <div class="container mt-4">

      <!-- ================= WELCOME ================= -->
      <div class="mb-4">
        <div class="welcome-title">
          Welcome back, <%= user.name %>! 👋
        </div>
        <div class="welcome-sub">
          Here's your mess subscription overview.
        </div>
      </div>

      <!-- ================= SUBSCRIPTION CARD ================= -->
      <div class="subscription-card mb-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
          <h5 class="mb-0">Monthly Mess Plan</h5>

          <% if(status === "Active"){ %>
            <span class="status-badge">Active</span>
          <% } %>
        </div>

        <div class="row mb-3">
          <div class="col-md-4">
            <small class="text-muted">Start Date</small>
            <div class="fw-semibold">
              <%= student.messSubscription?.startDate?.toDateString() %>
            </div>
          </div>

          <div class="col-md-4">
            <small class="text-muted">End Date</small>
            <div class="fw-semibold">
              <%= student.messSubscription?.endDate?.toDateString() %>
            </div>
          </div>

          <div class="col-md-4">
            <small class="text-muted">Days Left</small>
            <div class="fw-semibold">
              <%= daysRemaining > 0 ? daysRemaining : 0 %> days
            </div>
          </div>
        </div>

        <div class="progress-custom">
          <div class="progress-custom-bar"
            style="width:<%= (daysRemaining/30)*100 %>%">
          </div>
        </div>

      </div>

      <!-- ================= TWO COLUMN ================= -->
      <div class="row g-4">

        <!-- LEFT -->
        <div class="col-md-5">

          <!-- PAYMENT SUMMARY -->
          <div class="dashboard-card mb-4">
            <h5 class="mb-4">Payment Summary</h5>

            <div class="payments-amount">
              <div class="total-paid mb-3">
                <small class="text-muted">Total Paid</small>
                <div class="fs-4 fw-bold">₹<%= totalPaid %></div>
            </div>

            <% if(lastBill){ %>
              <div class="last-payment">
                  <small class="text-muted">Last Payment</small>
                  <div class="fw-semibold">
                    ₹<%= lastBill.amount %>
                  </div>
              <% } %>
              </div>
            </div>

            <div class="mt-3">
              <a href="/students/bills" class="btn-soft">
                View All Bills →
              </a>
            </div>
          </div>

          <!-- QUICK ACTIONS -->
          <div class="dashboard-card">
            <h5 class="mb-4">Quick Actions</h5>

            <a href="/student/billing" class="btn btn-outline-success w-100 mb-2 rounded-3">
              Pay Bill
            </a>

            <a href="/student/complaints" class="btn btn-outline-secondary w-100 mb-2 rounded-3">
              Raise Complaint
            </a>

            <a href="/student/menu" class="btn btn-outline-dark w-100 rounded-3">
              View Weekly Menu
            </a>
          </div>

        </div>

        <!-- RIGHT -->
        <div class="col-md-7">

          <!-- TODAY MENU -->
          <div class="dashboard-card">
            <div class="d-flex justify-content-between mb-3">
              <h5>Today's Menu</h5>
              <a href="/student/menu" class="text-decoration-none text-dark">
                Full Menu →
              </a>
            </div>

            <% menu.forEach(item => { %>
              <div class="menu-item">

                <div class="d-flex align-items-center gap-3">

                  <div class="icon-circle
                    <%= item.type === 'breakfast' ? 'icon-green'
                      : item.type === 'lunch' ? 'icon-yellow'
                      : 'icon-blue' %>">

                    <i class="bi 
                      <%= item.type === 'breakfast' ? 'bi-cup-hot'
                        : item.type === 'lunch' ? 'bi-sun'
                        : 'bi-moon' %>">
                    </i>

                  </div>

                  <div>
                    <div class="fw-semibold"><%= item.name %></div>
                    <small class="text-muted"><%= item.items %></small>
                  </div>

                </div>

                <small class="text-muted"><%= item.time %></small>

              </div>
            <% }) %>

          </div>

        </div>

      </div>

    </div>
    <%- include("../includes/footer") %>
  </div>
</div>