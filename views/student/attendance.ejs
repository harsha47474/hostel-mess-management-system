<% layout('layouts/boilerplate') -%>

    <div class="layout">

        <%- include("../includes/sidebar", { active: "attendance" }) %>

            <div class="main">

                <%- include("../includes/navbar", { user }) %>

                    <div class="content">

                        <% if (approved) { %>

                            <h2>
                                <%= meal %> Attendance
                            </h2>
                            <h3 style="color:green;">✅ Attendance Approved. You May Enter.</h3>

                            <% } else { %>

                                <h2>
                                    <%= meal %> QR Code
                                </h2>

                                <img id="qrImage" src="<%= qrImage %>" />

                                <p>Expires at: <%= expiresAt.toLocaleTimeString() %>
                                </p>

                                <h3 id="statusText">Waiting for scan...</h3>

                                <script>
                                    const token = "<%= token %>";

                                    function checkStatus() {
                                        fetch(`/qr-status/${token}`)
                                            .then(res => res.json())
                                            .then(data => {
                                                if (data.status === "used") {
                                                    document.getElementById("qrImage").style.display = "none";
                                                    document.getElementById("statusText").innerHTML =
                                                        "✅ Attendance Approved. You May Enter.";
                                                    document.getElementById("statusText").style.color = "green";
                                                }
                                            });
                                    }

                                    setInterval(checkStatus, 3000);
                                </script>

                                <% } %>


                    </div>

            </div>
    </div>